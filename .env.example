# LeverBot — Required Environment Variables
# Copy to .env or set in Render/your deployment platform

# ── Wallet ─────────────────────────────────────────
# Solana wallet private key (base58 or byte array)
SOLANA_PRIVATE_KEY=

# ── API Security ───────────────────────────────────
# Shared secret for dashboard API authentication (optional but recommended)
API_SECRET=

# ── Trading ────────────────────────────────────────
# Paper trading mode (true = demo, false = live)
PAPER_TRADING=true

# ── Telegram Alerts ────────────────────────────────
# Bot token from @BotFather
TG_BOT_TOKEN=
# Chat ID from @userinfobot
TG_CHAT_ID=

# ── Auto-Compound ──────────────────────────────────
# Reinvest profits automatically (true/false)
AUTO_COMPOUND=true

# ── Partial Sells ──────────────────────────────────
# Percentage to sell at first target (1-99, 100 = disabled)
PARTIAL_SELL_PCT=50

# ── Grid Settings ──────────────────────────────────
# Dynamic spread adjusts grid to volatility (true/false)
DYNAMIC_SPREAD=true
# Base spread for grid (0.05 = 5%)
BASE_SPREAD=0.05

# ── Risk Management ────────────────────────────────
# Max position size in USD
MAX_POSITION_USD=500
# Max daily loss in USD
MAX_DAILY_LOSS_USD=200
# Risk percentage per trade
RISK_PCT=2
# Cooldown between trades (seconds)
COOLDOWN=30
# Slippage tolerance (percentage)
SLIPPAGE=1.0

# ── Display ────────────────────────────────────────
# Server port
PORT=10000
# ── License ──────────────────────────────────────
# License key for LeverBot (format: LB-XXXX-XXXX-XXXX)
# Leave blank to run in demo mode (paper trading only)
LICENSE_KEY=
